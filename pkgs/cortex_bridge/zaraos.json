{
  "name": "cortex-bridge",
  "image": "ghcr.io/koalbymqp/cortex-bridge",
  "essential": true,
  "autostart": true,
  "depends": [],
  "env": {
    "ROS_DOMAIN_ID": "42",
    "RMW_IMPLEMENTATION": "rmw_cyclonedds_cpp"
  },
  "health_check": {
    "enabled": true,
    "restart_on_failure": true,
    "max_restarts": 3
  },
  "privileged": true,
  "volumes": [
    "/dev:/dev",
    "/sys:/sys:ro",
    "/run/udev:/run/udev:ro"
  ]
}
