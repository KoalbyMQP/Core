{
  "name": "startup-wizard",
  "image": "ghcr.io/koalbymqp/startup-wizard",
  "essential": true,
  "autostart": true,
  "depends": ["cortex-bridge"],
  "env": {
    "SDL_VIDEODRIVER": "kmsdrm",
    "SDL_AUDIODRIVER": "dummy",
    "ROS_DOMAIN_ID": "42",
    "RMW_IMPLEMENTATION": "rmw_cyclonedds_cpp"
  },
  "health_check": {
    "enabled": true,
    "restart_on_failure": true,
    "max_restarts": 3
  },
  "privileged": true,
  "volumes": [
    "/dev:/dev",
    "/sys:/sys:ro",
    "/data:/data",
    "/etc/hostname:/etc/hostname",
    "/etc/wpa_supplicant.conf:/etc/wpa_supplicant.conf",
    "/var/run/wpa_supplicant:/var/run/wpa_supplicant",
    "/run/udev:/run/udev:ro",
    "/run/containerd/containerd.sock:/run/containerd/containerd.sock"
  ],
  "run_condition": "!file_exists:/data/.setup-done"
}
