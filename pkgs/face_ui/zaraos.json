{
  "name": "face-ui",
  "image": "ghcr.io/koalbymqp/face-ui",
  "essential": true,
  "autostart": true,
  "depends": ["cortex-bridge"],
  "env": {
    "SDL_AUDIODRIVER": "dummy",
    "ROS_DOMAIN_ID": "42",
    "RMW_IMPLEMENTATION": "rmw_cyclonedds_cpp"
  },
  "health_check": {
    "enabled": true,
    "restart_on_failure": true,
    "max_restarts": 3
  },
  "privileged": true,
  "volumes": [
    "/dev:/dev",
    "/sys:/sys:ro",
    "/run/udev:/run/udev:ro"
  ],
  "run_condition": "file_exists:/data/.setup-done"
}
